{
  "name": "@nexus/cognitive-core",
  "version": "1.0.0",
  "private": true,
  "description": "Synthetic consciousness loop and synaptic memory engine for autonomous agents.",
  "author": "Cognitive Nexus Lab",
  "license": "UNLICENSED",
  "main": ".cognition/api.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "awaken": "ts-node-dev --respawn --transpile-only src/api.ts",
    "cortex": "ts-node-dev --respawn --transpile-only src/cognitive-engine.ts",
    "forge": "tsc",
    "ignite": "node .cognition/api.js",
    "ignite:cortex": "node .cognition/cognitive-engine.js",
    "synapse:test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "db:sync": "prisma generate && prisma migrate deploy"
  },
  "keywords": [
    "consciousness",
    "memory",
    "synapse",
    "graphrag",
    "nexus"
  ],
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@upstash/redis": "^1.35.8",
    "axios": "^1.6.8",
    "bullmq": "^5.66.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "node-cron": "^4.2.1",
    "openai": "^6.10.0",
    "stripe": "^26.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "prisma": "^5.16.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
